{
  "uid": "ads-delivery",
  "title": "Ads — decisioning and delivery",
  "description": "The serving path end to end: what ad-decision-service decided, why candidates lost, and what event-service recorded as actually delivered.",
  "tags": ["bellwether", "ads", "level-0"],
  "timezone": "utc",
  "schemaVersion": 39,
  "version": 1,
  "editable": false,
  "refresh": "10s",
  "time": { "from": "now-15m", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Fill rate",
      "description": "Share of ad requests that came back with an ad. The headline number for the serving path.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 5, "w": 8, "x": 0, "y": 0 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(ad_decisions_total{outcome=\"filled\"}[5m])) / clamp_min(sum(rate(ad_decisions_total[5m])), 0.001)",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 1,
          "min": 0,
          "max": 1,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#e66767", "value": null },
              { "color": "#c98500", "value": 0.5 },
              { "color": "#008300", "value": 0.8 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "value",
        "justifyMode": "auto",
        "orientation": "auto"
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Click-through rate",
      "description": "Clicks per impression, from the events actually reported to event-service.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 5, "w": 8, "x": 8, "y": 0 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(ad_events_total{event_type=\"click\"}[5m])) / clamp_min(sum(rate(ad_events_total{event_type=\"impression\"}[5m])), 0.001)",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 2,
          "min": 0,
          "color": { "mode": "fixed", "fixedColor": "#3987e5" }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "value",
        "justifyMode": "auto",
        "orientation": "auto"
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Duplicate reports rejected (1h)",
      "description": "Delivery reports whose event_id was already stored. A non-zero count is the idempotency key doing its job, not an error.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 5, "w": 8, "x": 16, "y": 0 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(ad_events_duplicate_total[1h]))",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "min": 0,
          "color": { "mode": "fixed", "fixedColor": "#9085e9" }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "value",
        "justifyMode": "auto",
        "orientation": "auto"
      }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Decisions by outcome",
      "description": "Ad requests per second, split into fills and no-fills.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 5 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (outcome) (rate(ad_decisions_total[1m]))",
          "legendFormat": "{{outcome}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "min": 0,
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 8,
            "showPoints": "never",
            "pointSize": 8,
            "spanNulls": false,
            "axisBorderShow": false,
            "gradientMode": "none"
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "filled" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "#3987e5" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "no_fill" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "#d95926" } }
            ]
          }
        ]
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Why candidates lost",
      "description": "Candidate campaigns per second by the rule that eliminated them. Stacked, so a fill-rate drop is read off the band that grew. Eligible candidates are excluded — they dwarf every rejection and would flatten the panel.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 5 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (reason) (rate(ad_candidates_filtered_total{reason!=\"eligible\"}[1m]))",
          "legendFormat": "{{reason}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "min": 0,
          "custom": {
            "drawStyle": "line",
            "lineWidth": 1,
            "fillOpacity": 55,
            "showPoints": "never",
            "pointSize": 8,
            "spanNulls": false,
            "axisBorderShow": false,
            "gradientMode": "none",
            "stacking": { "mode": "normal", "group": "A" }
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "brand_safety_excluded" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "#3987e5" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "frequency_capped" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "#d95926" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "no_creative" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "#199e70" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "not_active" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "#c98500" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "outside_flight_window" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "#d55181" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "pacing_throttled" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "#008300" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "targeting_mismatch" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "#9085e9" } }
            ]
          }
        ]
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "max"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Events ingested",
      "description": "Impressions and clicks per second accepted by event-service. The gap between fills here and fills on the decisions panel is reporting loss.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 14 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (event_type) (rate(ad_events_total[1m]))",
          "legendFormat": "{{event_type}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "min": 0,
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 8,
            "showPoints": "never",
            "pointSize": 8,
            "spanNulls": false,
            "axisBorderShow": false,
            "gradientMode": "none"
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "impression" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "#3987e5" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "click" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "#d95926" } }
            ]
          }
        ]
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Spend rate",
      "description": "Recorded advertiser spend per second, converted from micros. An estimate at a flat per-impression price, not billing (ADR-0003).",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 14 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(ad_spend_micros_total[1m])) / 1000000",
          "legendFormat": "spend"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "min": 0,
          "color": { "mode": "fixed", "fixedColor": "#3987e5" },
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 8,
            "showPoints": "never",
            "pointSize": 8,
            "spanNulls": false,
            "axisBorderShow": false,
            "gradientMode": "none"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": false },
        "tooltip": { "mode": "single", "sort": "none" }
      }
    }
  ]
}

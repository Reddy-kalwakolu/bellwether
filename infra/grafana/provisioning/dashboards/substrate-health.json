{
  "uid": "substrate-health",
  "title": "Substrate — service health",
  "description": "Traffic, errors, and latency for every substrate service, from the shared http_requests_total / http_request_duration_seconds pair in substrate/shared/observability.py.",
  "tags": ["bellwether", "substrate", "level-0"],
  "timezone": "utc",
  "schemaVersion": 39,
  "version": 1,
  "editable": false,
  "refresh": "10s",
  "time": { "from": "now-15m", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Scrape targets up",
      "description": "One tile per Prometheus job. Red means the service is not answering /metrics at all.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 5, "w": 6, "x": 0, "y": 0 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (job) (up)",
          "legendFormat": "{{job}}",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "color": { "mode": "thresholds" },
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN" }, "1": { "text": "UP" } } }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#e66767", "value": null },
              { "color": "#008300", "value": 1 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "value",
        "graphMode": "none",
        "textMode": "value_and_name",
        "justifyMode": "auto",
        "orientation": "auto"
      }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Request rate by service",
      "description": "Requests per second handled, from http_requests_total. The service label is what separates the three services sharing one metric name.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 5, "w": 18, "x": 6, "y": 0 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (service) (rate(http_requests_total[1m]))",
          "legendFormat": "{{service}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "min": 0,
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 8,
            "showPoints": "never",
            "pointSize": 8,
            "spanNulls": false,
            "axisBorderShow": false,
            "gradientMode": "none"
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "campaign-service" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "#3987e5" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "ad-decision-service" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "#d95926" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "event-service" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "#199e70" } }
            ]
          }
        ]
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["lastNotNull"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Error ratio by service",
      "description": "5xx responses as a share of all responses. clamp_min keeps an idle service at zero instead of NaN.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 5 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (service) (rate(http_requests_total{status=~\"5..\"}[5m])) / clamp_min(sum by (service) (rate(http_requests_total[5m])), 0.001)",
          "legendFormat": "{{service}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 8,
            "showPoints": "never",
            "pointSize": 8,
            "spanNulls": false,
            "axisBorderShow": false,
            "gradientMode": "none"
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "campaign-service" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "#3987e5" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "ad-decision-service" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "#d95926" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "event-service" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "#199e70" } }
            ]
          }
        ]
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "max"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "p95 request latency by service",
      "description": "95th percentile from the shared histogram. Per service rather than per endpoint on purpose — one line per entity, coloured the same everywhere on this dashboard.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 5 },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by (le, service) (rate(http_request_duration_seconds_bucket[5m])))",
          "legendFormat": "{{service}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "min": 0,
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 0,
            "showPoints": "never",
            "pointSize": 8,
            "spanNulls": false,
            "axisBorderShow": false,
            "gradientMode": "none"
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "campaign-service" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "#3987e5" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "ad-decision-service" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "#d95926" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "event-service" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "#199e70" } }
            ]
          }
        ]
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "max"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    }
  ]
}
